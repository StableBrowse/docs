            "group": "Concepts",
            "pages": [
              "concepts/businesses",
              "concepts/end-users",
              "concepts/sessions",
              "concepts/tasks",
              "concepts/platforms"
            ]
          },
          {
            "group": "SDKs",
            "pages": ["sdks/python", "sdks/typescript"]
          },
          {
            "group": "Reference",
            "pages": ["errors", "changelog"]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Tasks",
            "pages": [
              "api-reference/tasks/submit",
              "api-reference/tasks/get",
              "api-reference/tasks/list"
            ]
          },
          {
            "group": "Sessions",
            "pages": ["api-reference/sessions/get"]
